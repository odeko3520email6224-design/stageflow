# Copy this file to .env.local and fill in the values for your Base44 app.
VITE_BASE44_APP_ID=6a04d375dd2d16805b295b5a
VITE_BASE44_APP_BASE_URL=https://stage-flow-map.base44.app

# Optional local-only server-side key for testing writes through the Vite /api proxy.
# Never prefix this with VITE_ and never commit real keys.
BASE44_API_KEY=your_local_base44_api_key

# Optional: use this when you need to pin a deployed Base44 functions version locally.
# VITE_BASE44_FUNCTIONS_VERSION=prod
